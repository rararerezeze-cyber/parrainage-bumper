- name: 🚀 Bump Code Parrainage & Parrainage.co
        env:
          CODE_PARRAINAGE_EMAIL:     ${{ secrets.CODE_PARRAINAGE_EMAIL }}
          CODE_PARRAINAGE_PASSWORD:  ${{ secrets.CODE_PARRAINAGE_PASSWORD }}
          PARRAINAGE_CO_EMAIL:       ${{ secrets.PARRAINAGE_CO_EMAIL }}
          PARRAINAGE_CO_PASSWORD:    ${{ secrets.PARRAINAGE_CO_PASSWORD }}
          PARRAINAGE_CO_RM_COOKIE:   ${{ secrets.PARRAINAGE_CO_RM_COOKIE }}
          TARGET_SITES:              "code,parrainage"
          DISPLAY:                   ":99"
        run: |
          sudo apt-get install -y xvfb
          Xvfb :99 -screen 0 1280x800x24 &
          sleep 2
          python bumper.py
